   460	/// TRACE_MATRIX FC3-S3: TB-2 `TransitionError → L4ERejectionClass` mapping
   461	/// (preflight v3 §3.7). Closed by enumeration via the documented table even
   462	/// though the `match` uses `_` for the 19-variant tail: WorkTx-arm-reachable
   463	/// variants are explicit; non-WorkTx-arm variants fall through to
   464	/// `PolicyViolation` per Codex r2 P0-4 sanction.
   465	fn rejection_class_for(e: &TransitionError) -> L4ERejectionClass {
   466	    use TransitionError as TE;
   467	    use L4ERejectionClass as RC;
   468	    match e {
   469	        TE::AcceptancePredicateFailed(_)
   470	        | TE::VerificationPredicateFailed(_)
   471	        | TE::SettlementPredicateFailed(_) => RC::PredicateFailed,
   472	        TE::EscrowMissing => RC::EscrowMissing,
   473	        TE::MonetaryInvariantViolation => RC::InvariantViolation,
   474	        // TB-3 RSP-1 formal-tx-surface mapping (charter § 4.5):
   475	        TE::TaskAlreadyOpen => RC::PolicyViolation,
   476	        // TB-3 charter § 4.5: TaskNotOpen reuses EscrowMissing semantically —
   477	        // "no open task = no funded admission path".
   478	        TE::TaskNotOpen => RC::EscrowMissing,
   479	        // TB-3 charter § 4.5 + § 3.5: InsufficientBalance is its OWN L4E class
   480	        // (do NOT fold into PolicyViolation — P4 Information Loom needs the
   481	        // discriminator).
   482	        TE::InsufficientBalance => RC::InsufficientBalance,
   483	        // TB-4 RSP-2 admission mapping (charter § 4.5; directive Q3 + Q7).
   484	        // All 3 new TB-4 variants + 2 reserved variants cluster under
   485	        // PolicyViolation at the L4ERejectionClass coarser tier; finer-grained
   486	        // TransitionError variant name is recoverable from the L4.E
   487	        // raw_diagnostic_cid CAS payload (preflight § 8 Q2).
   488	        TE::BondInsufficient => RC::PolicyViolation,
   489	        TE::TargetWorkInactive => RC::PolicyViolation,
   490	        TE::EmptyCounterexample => RC::PolicyViolation,
   491	        TE::TargetWorkTxNotFound => RC::PolicyViolation,
   492	        TE::TargetWorkTxNotVerifiable => RC::PolicyViolation,
   493	        // TB-5 RSP-3.0/3.1 (charter v2 § 4.5):
   494	        TE::SystemTxForbiddenOnAgentIngress => RC::PolicyViolation,
   495	        TE::InvalidSystemSignatureLive => RC::PolicyViolation,
   496	        TE::ChallengeNotFound => RC::PolicyViolation,
   497	        TE::AlreadyResolved => RC::PolicyViolation,
   498	        // TB-8 Atom 3 (charter § 4.5):
   499	        TE::ClaimAlreadyFinalized => RC::PolicyViolation,
   500	        TE::ChallengeWindowStillOpen => RC::PolicyViolation,
   501	        // TB-N1-AGENT-ECONOMY Phase 2 A3 (2026-05-10): agent-declared stake
   502	        // exceeds available balance. Maps to `InsufficientBalance` —
   503	        // architecturally honest (same L4E class as Step-6 system-side
   504	        // solvency check), gives Information Loom a per-tx-class signal
   505	        // distinguishing "agent over-committed" from "stake = 0".
   506	        TE::StakeBalanceExceeded => RC::InsufficientBalance,
   507	        // TB-N1-AGENT-ECONOMY Phase 2 A4 (2026-05-10): VerifyTx agent-side
   508	        // rejection telemetry. VerifyBondOutOfBounds → InsufficientBalance
   509	        // (mirrors A3's StakeBalanceExceeded mapping; agent has insufficient
   510	        // balance for declared bond). VerifyTargetNotAccepted +
   511	        // VerifyDuplicate → PolicyViolation (charter §4.5 + directive Q7
   512	        // precedent for VerifyTx-arm catch-all class).
   513	        TE::VerifyBondOutOfBounds => RC::InsufficientBalance,
   514	        TE::VerifyTargetNotAccepted => RC::PolicyViolation,
   515	        TE::VerifyDuplicate => RC::PolicyViolation,
   516	        // TB-N2 B2 (2026-05-11): EventResolveTx admission failure classes.
   517	        // Both → PolicyViolation (system-tx admission policy; not agent
   518	        // balance / stake-side rejection). EventResolveTaskNotFound = system
   519	        // emit referenced a non-existent task; EventAlreadyResolved =
   520	        // idempotent re-emit / post-Bankrupt / post-Expired. Conservative-
   521	        // merge consistent with TB-5 SystemTxForbiddenOnAgentIngress + TB-11
   522	        // TaskBankruptcy-arm classes (all → PolicyViolation).
   523	        TE::EventResolveTaskNotFound => RC::PolicyViolation,
   524	        TE::EventAlreadyResolved => RC::PolicyViolation,
   525	        // Non-WorkTx-arm variants documented per §3.7 mapping table — should
   526	        // not occur on the WorkTx arm; conservative sentinel preserves L4.E
   527	        // append correctness if a future TB adds new variants.
   528	        _ => RC::PolicyViolation,
   529	    }
   530	}
