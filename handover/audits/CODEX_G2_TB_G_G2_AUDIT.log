    59	    ///
    60	    /// TRACE_MATRIX FC1-N5 (TB-G G2.2 2026-05-12; §F walker for
    61	    /// MarketDecisionTrace summary).
    62	    pub fn compute_from_cas(
    63	        cas: &crate::bottom_white::cas::store::CasStore,
    64	    ) -> Self {
    65	        let mut outcome_counts: BTreeMap<String, u64> = BTreeMap::new();
    66	        let mut no_trade_breakdown: BTreeMap<NoTradeReason, u64> = BTreeMap::new();
    67	        let mut total_traces: u64 = 0;
    68	        let mut submitted_count: u64 = 0;
    69	        for entry in cas.list_all_cids() {
