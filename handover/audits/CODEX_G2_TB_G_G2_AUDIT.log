    52	
    53	impl MarketDecisionTraceSummary {
    54	    /// Walk every CID in the CAS store and tally
    55	    /// `tb_n3.market_decision_trace.v1` objects. Non-trace CIDs are
    56	    /// silently skipped (we share the AttemptTelemetry ObjectType slot
    57	    /// per the trace module's CAS write path — `schema_version` is the
