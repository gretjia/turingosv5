   428	// ────────────────────────────────────────────────────────────────────────
   429	// SG-G2.5.d — end-to-end architect §8.6 verbatim "Failed invest 也算有
   430	// 意义 tape activity": router-side rejection in L4.E AND caller-side
   431	// MarketDecisionTrace::no_trade(RouterRejected) trace in CAS.
   432	// ────────────────────────────────────────────────────────────────────────
   433	
   434	#[tokio::test]
   435	async fn sg_g2_5_d_failed_invest_both_l4e_and_cas_trace() {
   436	    // Setup: bob has 1 Coin; attempts 5 Coin pay. Sequencer rejects;
   437	    // evaluator-side pattern writes the trace with `RouterRejected`.
   438	    let q0 = genesis_with_balances_and_open_task(&[("alice", 50), ("bob", 1)], "evt-4");
   439	    let mut h = fresh_harness(q0);
   440	    let parent = seed_pool(&mut h, "alice", "evt-4", 5_000_000).await;
   441	
   442	    let submit_result = submit_and_apply(
   443	        &mut h,
   444	        build_router(parent, "bob", "evt-4", BuyDirection::BuyYes, 5_000_000, 0, 1),
   445	    )
   446	    .await;
   447	    assert!(
   448	        submit_result.is_err(),
   449	        "SG-G2.5.d: router admission must reject"
   450	    );
   451	
   452	    // L4.E half: rejection record exists.
   453	    let recs = router_rejection_records(&h);
   454	    assert!(
   455	        recs.iter().any(|(k, c)| *k == TxKind::BuyWithCoinRouter
   456	            && *c == RejectionClass::PolicyViolation),
   457	        "SG-G2.5.d: L4.E must carry the rejected BuyWithCoinRouter (coarse \
   458	         PolicyViolation class; fine-grained TransitionError::RouterInsufficientCoinBalance \
   459	         in raw_diagnostic_cid); got {:?}",
   460	        recs
   461	    );
   462	
   463	    // CAS-trace half: evaluator pattern writes MarketDecisionTrace::no_trade
   464	    // with reason = RouterRejected (the canonical no-trade-reason for a
   465	    // sequencer-side router rejection, per InvestRouteError::to_no_trade_reason
   466	    // mapping convention; the pre-classifier handles balance-side via
   467	    // AmountExceedsBalance but a real Tx ALSO submitted to the sequencer
   468	    // would have been caught by `tb_n3_invest_to_router_tx`).
   469	    let cas_dir = TempDir::new().expect("tempdir cas");
   470	    let mut cas = CasStore::open(cas_dir.path()).expect("cas");
   471	    let trace = MarketDecisionTrace::no_trade(
   472	        AgentId("bob".into()),
   473	        None,
   474	        Some(BuyDirection::BuyYes),
   475	        Some(5_000_000),
   476	        NoTradeReason::RouterRejected,
   477	        "router rejected: RouterInsufficientCoinBalance",
   478	    );
   479	    write_market_decision_trace_to_cas(&mut cas, &trace, "g2-5-d", 1).expect("write trace");
   480	    drop(cas);
   481	
   482	    let summary =
   483	        MarketDecisionTraceSummary::compute_from_path(cas_dir.path()).expect("summary");
   484	    assert_eq!(summary.total_traces, 1);
   485	    assert_eq!(
   486	        summary.no_trade_breakdown.get(&NoTradeReason::RouterRejected),
   487	        Some(&1),
   488	        "SG-G2.5.d: CAS trace must reflect RouterRejected count = 1"
   489	    );
   490	}

