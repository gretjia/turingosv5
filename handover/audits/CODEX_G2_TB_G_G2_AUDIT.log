    75	                Ok(t) => t,
    76	                Err(_) => continue,
    77	            };
    78	            if trace.schema_version != MarketDecisionTrace::SCHEMA_VERSION {
    79	                continue;
    80	            }
    81	            total_traces += 1;
    82	            match &trace.outcome {
    83	                TraceOutcome::Submitted { .. } => {
    84	                    *outcome_counts.entry("submitted".into()).or_insert(0) += 1;
    85	                    submitted_count += 1;
    86	                }
    87	                TraceOutcome::NoTrade { reason, .. } => {
    88	                    *outcome_counts.entry("no_trade".into()).or_insert(0) += 1;
    89	                    *no_trade_breakdown.entry(*reason).or_insert(0) += 1;
    90	                }
    91	                TraceOutcome::Declined => {
    92	                    *outcome_counts.entry("declined".into()).or_insert(0) += 1;
    93	                }
    94	            }
    95	        }
    96	        Self {
    97	            total_traces,
    98	            outcome_counts,
    99	            no_trade_breakdown,
