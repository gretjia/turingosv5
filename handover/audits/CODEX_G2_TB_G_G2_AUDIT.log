   532	/// TRACE_MATRIX FC3-S3: TB-2 agent-facing summary string for an L4.E record.
   533	///
   534	/// Returns a small, predicate-id-stripped class label so private predicate
   535	/// identities never leak (TB-1 §1.4 "Opaque" discipline). The wildcard arm
   536	/// matches the §3.7 mapping policy and is the documented sentinel for
   537	/// non-WorkTx-arm variants per Codex r2 P0-4.
   538	fn public_summary_for(e: &TransitionError) -> Option<String> {
   539	    match e {
   540	        TransitionError::StaleParent => Some("stale_parent_root".into()),
   541	        TransitionError::StakeInsufficient => Some("stake_insufficient".into()),
   542	        TransitionError::EscrowMissing => Some("escrow_missing".into()),
   543	        TransitionError::MonetaryInvariantViolation => Some("monetary_invariant".into()),
   544	        TransitionError::AcceptancePredicateFailed(_)
   545	        | TransitionError::SettlementPredicateFailed(_) => Some("predicate_failed".into()),
   546	        // TB-3 RSP-1 formal-tx-surface (charter § 4.5).
   547	        TransitionError::TaskAlreadyOpen => Some("task_already_open".into()),
   548	        TransitionError::TaskNotOpen => Some("task_not_open".into()),
   549	        TransitionError::InsufficientBalance => Some("insufficient_balance".into()),
   550	        // TB-4 RSP-2 admission (charter § 4.5; directive Q3 + Q7).
   551	        TransitionError::BondInsufficient => Some("bond_insufficient".into()),
   552	        TransitionError::TargetWorkInactive => Some("target_work_inactive".into()),
   553	        TransitionError::EmptyCounterexample => Some("empty_counterexample".into()),
   554	        TransitionError::TargetWorkTxNotFound => Some("target_work_not_found".into()),
   555	        TransitionError::TargetWorkTxNotVerifiable => Some("target_work_not_verifiable".into()),
   556	        // TB-5 RSP-3.0/3.1.
   557	        TransitionError::SystemTxForbiddenOnAgentIngress => Some("system_tx_forbidden_on_agent_ingress".into()),
   558	        TransitionError::InvalidSystemSignatureLive => Some("invalid_system_signature_live".into()),
   559	        TransitionError::ChallengeNotFound => Some("challenge_not_found".into()),
   560	        TransitionError::AlreadyResolved => Some("already_resolved".into()),
   561	        // TB-8 Atom 3.
   562	        TransitionError::ClaimAlreadyFinalized => Some("claim_already_finalized".into()),
   563	        TransitionError::ChallengeWindowStillOpen => Some("challenge_window_still_open".into()),
   564	        // TB-N1-AGENT-ECONOMY Phase 2 A3 (2026-05-10): agent-decided stake
   565	        // bound exceeded. Distinct public-summary tag so per-tx-class
   566	        // telemetry distinguishes from `stake_insufficient` (zero stake)
   567	        // and `insufficient_balance` (system-side solvency).
   568	        TransitionError::StakeBalanceExceeded => Some("stake_balance_exceeded".into()),
   569	        // TB-N1-AGENT-ECONOMY Phase 2 A4 (2026-05-10): VerifyTx agent-side
   570	        // rejection telemetry. Three distinct public-summary tags so
   571	        // per-tx-class telemetry distinguishes the verify-peer failure
   572	        // modes (bound vs target-missing vs duplicate).
   573	        TransitionError::VerifyBondOutOfBounds => Some("verify_bond_out_of_bounds".into()),
   574	        TransitionError::VerifyTargetNotAccepted => Some("verify_target_not_accepted".into()),
   575	        TransitionError::VerifyDuplicate => Some("verify_duplicate".into()),
   576	        // TB-N2 B2 (2026-05-11): EventResolveTx admission failure summaries.
   577	        // Public-summary tags distinguish the two failure modes for
   578	        // Information Loom signal.
   579	        TransitionError::EventResolveTaskNotFound => Some("event_resolve_task_not_found".into()),
   580	        TransitionError::EventAlreadyResolved => Some("event_already_resolved".into()),
   581	        _ => Some("policy_violation".into()),
   582	    }
   583	}
