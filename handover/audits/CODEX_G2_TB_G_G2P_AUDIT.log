111:#[test]
112:fn sg_g2p_1_renderer_does_not_reference_private_surfaces() {
113:    let src = std::fs::read_to_string(PENDING_PEER_REVIEWS_SRC)
114:        .expect("pending_peer_reviews.rs readable");
115:    // Strip comment lines so that doc-prose mentioning "raw Lean stderr"
116:    // (as a description of what is forbidden) doesn't trip the gate.
117:    // Forbidden tokens must not appear in code (non-comment) lines.
118:    let code: String = src
119:        .lines()
120:        .filter(|l| {
121:            let t = l.trim_start();
122:            !t.starts_with("//") && !t.starts_with("///") && !t.starts_with("//!")
123:        })
124:        .collect::<Vec<&str>>()
125:        .join("\n");
126:    let forbidden = [
127:        "attempt_telemetry",
128:        "AttemptTelemetry",
129:        "prompt_capsule",
130:        "PromptCapsule",
131:        "proof_artifact",
132:        "proposal_cid",
133:        "raw_stderr",
134:        "lean_stderr",
135:        "private_diagnostic",
136:        "chain_of_thought",
137:        "pput",
138:        "PPUT",
139:    ];
140:    for needle in &forbidden {
141:        assert!(
142:            !code.contains(needle),
143:            "SG-G2P.1 shielding violation: renderer code references \
144:             forbidden private surface `{needle}` — would leak peer CoT \
145:             or private-diagnostic content per CLAUDE.md §15."
146:        );
147:    }
148:}
