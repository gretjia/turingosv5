100:/// TRACE_MATRIX FC1-N7 — TB-G G2P.2 SG-G2P.3 walker: emit per-agent
101:/// `peer_verify_count` from canonical L4 + CAS evidence.
102:///
103:/// Walks `1..=writer.len()`, decodes each entry's payload from CAS as
104:/// `TypedTx`, and accumulates the per-axis counts. Trait-object-typed
105:/// to admit both `Git2LedgerWriter` (production) and
106:/// `InMemoryLedgerWriter` (tests).
107:pub fn compute_peer_verify_coverage(
108:    writer: &dyn LedgerWriter,
109:    cas: &CasStore,
110:) -> Result<PeerVerifyCoverage, PeerVerifyCoverageError> {
111:    let mut cov = PeerVerifyCoverage::default();
112:    let mut accepted_worktx_ids: BTreeSet<TxId> = BTreeSet::new();
113:    let l4_count = writer.len();
114:    for t in 1..=l4_count {
115:        let entry = writer.read_at(t)?;
116:        let payload = match cas.get(&entry.tx_payload_cid) {
117:            Ok(b) => b,
118:            Err(_) => continue,
119:        };
120:        let typed_tx: TypedTx = match canonical_decode(&payload) {
121:            Ok(t) => t,
122:            Err(_) => continue,
123:        };
124:        match &typed_tx {
125:            TypedTx::Work(work) => {
126:                accepted_worktx_ids.insert(work.tx_id.clone());
127:                cov.solver_agents.insert(work.agent_id.clone());
128:            }
129:            TypedTx::Verify(verify) => {
130:                cov.peer_verifications_total += 1;
131:                *cov.per_verifier_count
132:                    .entry(verify.verifier_agent.clone())
133:                    .or_insert(0) += 1;
134:                *cov.per_target_count
135:                    .entry(verify.target_work_tx.clone())
136:                    .or_insert(0) += 1;
137:            }
138:            _ => {}
139:        }
140:    }
141:    cov.accepted_worktx_total = accepted_worktx_ids.len() as u64;
142:    cov.accepted_worktx_with_verify = accepted_worktx_ids
143:        .iter()
144:        .filter(|id| cov.per_target_count.get(id).copied().unwrap_or(0) > 0)
145:        .count() as u64;
146:    cov.coverage_pct = if cov.accepted_worktx_total > 0 {
147:        (cov.accepted_worktx_with_verify.saturating_mul(100))
148:            / cov.accepted_worktx_total
149:    } else {
150:        0
151:    };
152:    cov.non_solver_verifications = cov
153:        .per_verifier_count
154:        .iter()
155:        .filter(|(verifier, _)| !cov.solver_agents.contains(*verifier))
156:        .map(|(_, n)| *n)
157:        .sum();
158:    Ok(cov)
159:}
