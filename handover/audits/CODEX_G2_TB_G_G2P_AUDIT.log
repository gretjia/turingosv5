161:/// TRACE_MATRIX FC1-N7 — TB-G G2P.2 path-based wrapper for the
162:/// `audit_dashboard --run-report` §F.X integration. Opens the
163:/// `Git2LedgerWriter` at `runtime_repo_path` + `CasStore` at `cas_path`
164:/// and delegates to `compute_peer_verify_coverage`.
165:pub fn compute_peer_verify_coverage_from_paths(
166:    runtime_repo_path: &Path,
167:    cas_path: &Path,
168:) -> Result<PeerVerifyCoverage, PeerVerifyCoverageError> {
169:    let writer = Git2LedgerWriter::open(runtime_repo_path)
170:        .map_err(PeerVerifyCoverageError::LedgerOpen)?;
171:    let cas = CasStore::open(cas_path).map_err(|e| PeerVerifyCoverageError::CasOpen(e.to_string()))?;
172:    compute_peer_verify_coverage(&writer, &cas)
173:}
