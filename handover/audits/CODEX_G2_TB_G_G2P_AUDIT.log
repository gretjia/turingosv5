175:impl PeerVerifyCoverage {
176:    /// TRACE_MATRIX FC1-N7 — TB-G G2P.2 SG-G2P.4 + SG-G2P.5 render: emit
177:    /// the `## §F.X Peer-verify coverage` dashboard section. Includes an
178:    /// EXPLICIT mechanism-bottleneck explanation when
179:    /// `non_solver_verifications == 0` (no silent zero per
180:    /// `feedback_no_workarounds_strict_constitution`).
181:    pub fn render_section_f_x(&self) -> String {
182:        let mut out = String::new();
183:        out.push_str("\n## §F.X Peer-verify coverage\n");
184:        out.push_str(&format!(
185:            "  accepted_worktx_total: {}\n",
186:            self.accepted_worktx_total
187:        ));
188:        out.push_str(&format!(
189:            "  accepted_worktx_with_verify: {}\n",
190:            self.accepted_worktx_with_verify
191:        ));
192:        out.push_str(&format!("  coverage_pct: {}%\n", self.coverage_pct));
193:        out.push_str(&format!(
194:            "  peer_verifications_total: {}\n",
195:            self.peer_verifications_total
196:        ));
197:        out.push_str(&format!(
198:            "  non_solver_verifications: {}\n",
199:            self.non_solver_verifications
200:        ));
201:        if !self.per_verifier_count.is_empty() {
202:            out.push_str("  per-agent peer_verify_count:\n");
203:            let mut rows: Vec<(&AgentId, &u64)> = self.per_verifier_count.iter().collect();
204:            rows.sort_by(|a, b| b.1.cmp(a.1).then_with(|| a.0.0.cmp(&b.0.0)));
205:            for (agent, n) in rows.iter().take(20) {
206:                let role = if self.solver_agents.contains(agent) {
207:                    "solver"
208:                } else {
209:                    "non_solver"
210:                };
211:                out.push_str(&format!("    - {} ({}): {}\n", agent.0, role, n));
212:            }
213:        }
214:        if self.non_solver_verifications == 0 {
215:            out.push_str("  MECHANISM BOTTLENECK (architect §8.2 ship gate unmet — no non-solver VerifyTx):\n");
216:            out.push_str("    1. round-robin scheduler `agent_idx = tx % n_agents`\n");
217:            out.push_str("       (G-Phase directive amendment G-4 \"伪多智能体\"):\n");
218:            out.push_str("       Agent_i may never be selected for verify path;\n");
219:            out.push_str("       G5.1 opportunity scheduler + 7-action menu is the\n");
220:            out.push_str("       forward fix.\n");
221:            out.push_str("    2. `=== Pending Peer Reviews ===` prompt block (G2P.1)\n");
222:            out.push_str("       must be active on the swarm prompt path so agents\n");
223:            out.push_str("       perceive eligible targets at the δ Agent externalized\n");
224:            out.push_str("       output node.\n");
225:            out.push_str("    3. agent verify_peer bond budget (TB-N1 A4 admission step-2.5)\n");
226:            out.push_str("       may exceed balance after WorkTx stake locked — confirm\n");
227:            out.push_str("       persistent-batch preseed (TURINGOS_CHAINTAPE_PRESEED=1)\n");
228:            out.push_str("       seeds non-solver agents with adequate balance.\n");
229:        }
230:        out
231:    }
232:}
