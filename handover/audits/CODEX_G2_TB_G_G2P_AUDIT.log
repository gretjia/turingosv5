38:pub const DEFAULT_PENDING_REVIEWS_K: usize = 5;
39:
40:/// TRACE_MATRIX FC1-N7 + §15 + G-Phase directive §0.6 amendment G-2:
41:/// agent perceives the queue of accepted peer WorkTxs eligible for its
42:/// own `verify_peer` tool call at the δ / Agent externalized output node.
43:///
44:/// Render the pending-peer-reviews block (body only; the
45:/// `=== Pending Peer Reviews ===` heading is added by the prompt builder).
46:///
47:/// Per-viewer filter:
48:/// 1. iterate `q.economic_state_t.stakes_t.0` (canonical L4-accepted-WorkTx index)
49:/// 2. drop `staker == viewer` (no self-verify)
50:/// 3. drop `(viewer, tx_id) ∈ agent_verifications_t` (no duplicate-verify griefing)
51:/// 4. compute `already_verified_by_peers = |{v : (v, tx_id) ∈ agent_verifications_t}|`
52:///
53:/// Sort: stake desc (highest-stake WorkTxs first → market signal +
54:/// highest verify reward potential under TB-N1 A4 reputation accrual),
55:/// tiebreak by `tx_id` asc for determinism.
56:///
57:/// Returns empty string when no candidates exist; the prompt builder
58:/// suppresses the entire block in that case (mirrors `econ_position.rs`
59:/// suppression contract — V3L-40 layout stability across runs).
60:///
61:/// `K` caps the number of rows rendered. `DEFAULT_PENDING_REVIEWS_K = 5`
62:/// keeps prompt budget bounded.
63:pub fn render_pending_peer_reviews(q: &QState, viewer: &AgentId, k: usize) -> String {
64:    let mut candidates: Vec<(String, String, String, i64, usize)> = Vec::new();
65:    for (tx_id, stake_entry) in q.economic_state_t.stakes_t.0.iter() {
66:        if &stake_entry.staker == viewer {
67:            continue;
68:        }
69:        if q
70:            .economic_state_t
71:            .agent_verifications_t
72:            .0
73:            .contains(&(viewer.clone(), tx_id.clone()))
74:        {
75:            continue;
76:        }
77:        let already_verified_by = q
78:            .economic_state_t
79:            .agent_verifications_t
80:            .0
81:            .iter()
82:            .filter(|(_, t)| t == tx_id)
83:            .count();
84:        candidates.push((
85:            tx_id.0.clone(),
86:            stake_entry.staker.0.clone(),
87:            stake_entry.task_id.0.clone(),
88:            stake_entry.amount.micro_units(),
89:            already_verified_by,
90:        ));
91:    }
92:    if candidates.is_empty() {
93:        return String::new();
94:    }
95:    candidates.sort_by(|a, b| b.3.cmp(&a.3).then_with(|| a.0.cmp(&b.0)));
96:    let mut s = String::new();
97:    for (tx_id, proposer, task_id, stake_micro, verifier_count) in candidates.iter().take(k) {
98:        s.push_str(&format!(
99:            "- work_tx {tx_id}: proposer={proposer} task={task_id} stake={stake_micro} \u{03BC}Coin already_verified_by={verifier_count} peer(s)\n"
100:        ));
101:    }
102:    s.push_str(
103:        "Submit a `verify_peer` action against one of the above target_work_tx_ids if you can judge the proof step \
104:         (verdict=confirm if correct; verdict=deny if wrong). Your bond is debited from balance until the run resolves; correct verdict earns reward.\n",
105:    );
106:    s
107:}
