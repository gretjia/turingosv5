51:pub struct PeerVerifyCoverage {
52:    /// Number of distinct accepted WorkTx tx_ids on the chain.
53:    pub accepted_worktx_total: u64,
54:    /// Number of accepted WorkTx tx_ids that have ≥1 accepted VerifyTx
55:    /// targeting them.
56:    pub accepted_worktx_with_verify: u64,
57:    /// `floor(100 * accepted_worktx_with_verify / accepted_worktx_total)`.
58:    /// Zero when `accepted_worktx_total == 0` (no division-by-zero panic).
59:    pub coverage_pct: u64,
60:    /// Total accepted VerifyTxs on the chain.
61:    pub peer_verifications_total: u64,
62:    /// Accepted VerifyTxs whose `verifier_agent` did NOT also submit any
63:    /// accepted WorkTx on this chain — the architect §8.2 health signal.
64:    pub non_solver_verifications: u64,
65:    /// per-verifier accepted-VerifyTx count (`verifier_agent` → count).
66:    pub per_verifier_count: BTreeMap<AgentId, u64>,
67:    /// per-target accepted-VerifyTx count (`target_work_tx` → count).
68:    pub per_target_count: BTreeMap<TxId, u64>,
69:    /// Agents who submitted ≥1 accepted WorkTx on this chain.
70:    pub solver_agents: BTreeSet<AgentId>,
71:}
