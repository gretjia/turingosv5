2048:/// TB-N3 A5 — render the §A..§G run-report block for a TB-N3 batch run.
2049:/// Walks L4 + CAS to surface tx_kind counts, top contested nodes, budget
2050:/// burn, MarketDecisionTrace aggregate, signal-not-truth banner. Caller
2051:/// (`audit_dashboard --run-report`) appends this to the legacy 16-section
2052:/// dashboard render.
2053:fn render_tb_n3_run_report(
2054:    report: &DashboardReport,
2055:    repo: &std::path::Path,
2056:    cas_path: &std::path::Path,
2057:) -> String {
2058:    use std::collections::BTreeMap;
2059:    use turingosv4::bottom_white::cas::store::CasStore;
2060:    use turingosv4::bottom_white::ledger::transition_ledger::{
2061:        canonical_decode, Git2LedgerWriter,
2062:    };
2063:    use turingosv4::runtime::market_decision_trace::{
2064:        MarketDecisionTrace, NoTradeReason, TraceOutcome,
2065:    };
2066:
2067:    let mut out = String::new();
2068:    out.push_str("\n=== TB-N3 RUN REPORT ===\n");
2069:    out.push_str(&format!("run_id: {}\n", report.run_id));
2070:    out.push_str(&format!("epoch: {}\n", report.epoch));
2071:
2072:    // Walk the L4 ledger once to count tx-kinds and gather node-survive
2073:    // pool / market-seed / router activity.
2074:    let writer = match Git2LedgerWriter::open(repo) {
2075:        Ok(w) => w,
2076:        Err(e) => {
2077:            out.push_str(&format!("\n[error] open L4 ledger: {e:?}\n"));
2078:            return out;
2079:        }
2080:    };
2081:    let l4_count = writer.len();
2082:    let cas = match CasStore::open(cas_path) {
2083:        Ok(c) => c,
2084:        Err(e) => {
2085:            out.push_str(&format!("\n[error] open CAS: {e}\n"));
2086:            return out;
2087:        }
2088:    };
2089:
2090:    let mut tx_kind_counts: BTreeMap<String, u64> = BTreeMap::new();
2091:    let mut market_seed_total_micro: i64 = 0;
2092:    let mut pools_created: u64 = 0;
2093:    let mut router_count_yes: u64 = 0;
2094:    let mut router_count_no: u64 = 0;
2095:    let mut node_event_seeds: BTreeMap<String, i64> = BTreeMap::new();
2096:
2097:    for t in 1..=l4_count {
2098:        let entry = match writer.read_at(t) {
2099:            Ok(e) => e,
2100:            Err(_) => continue,
2101:        };
2102:        let payload = match cas.get(&entry.tx_payload_cid) {
2103:            Ok(b) => b,
2104:            Err(_) => continue,
2105:        };
2106:        let typed_tx: TypedTx = match canonical_decode(&payload) {
2107:            Ok(t) => t,
2108:            Err(_) => continue,
2109:        };
2110:        let kind = format!("{:?}", typed_tx.tx_kind());
2111:        *tx_kind_counts.entry(kind).or_insert(0) += 1;
2112:        match &typed_tx {
2113:            TypedTx::MarketSeed(seed) => {
2114:                let inner = &seed.event_id.0.0;
2115:                if inner.starts_with("node_survive:") {
2116:                    market_seed_total_micro += seed.collateral_amount.micro_units();
2117:                    node_event_seeds
2118:                        .entry(inner.clone())
2119:                        .and_modify(|v| *v += seed.collateral_amount.micro_units())
2120:                        .or_insert(seed.collateral_amount.micro_units());
2121:                }
2122:            }
2123:            TypedTx::CpmmPool(pool) => {
2124:                let inner = &pool.event_id.0.0;
2125:                if inner.starts_with("node_survive:") {
2126:                    pools_created += 1;
2127:                }
2128:            }
2129:            TypedTx::BuyWithCoinRouter(router) => {
2130:                use turingosv4::state::typed_tx::BuyDirection;
2131:                match router.direction {
2132:                    BuyDirection::BuyYes => router_count_yes += 1,
2133:                    BuyDirection::BuyNo => router_count_no += 1,
2134:                }
2135:            }
2136:            _ => {}
2137:        }
2138:    }
2139:
2140:    // §A Citation tree (minimal first-cut: list accepted Work tx_ids
2141:    // grouped by agent; full tree is a forward enhancement).
2142:    out.push_str("\n## §A Citation tree (accepted WorkTx by agent)\n");
2143:    let mut work_by_agent: BTreeMap<String, Vec<String>> = BTreeMap::new();
2144:    for (agent, act) in &report.per_agent {
2145:        if act.work_tx_accepted == 0 {
2146:            continue;
2147:        }
2148:        work_by_agent
2149:            .entry(agent.clone())
2150:            .or_default()
2151:            .push(format!("{} accepted WorkTx", act.work_tx_accepted));
2152:    }
2153:    if work_by_agent.is_empty() {
2154:        out.push_str("  (no accepted WorkTx in run)\n");
2155:    } else {
2156:        for (agent, lines) in &work_by_agent {
2157:            out.push_str(&format!("  - {}: {}\n", agent, lines.join(", ")));
2158:        }
2159:    }
2160:
2161:    // §B Role activity (already in DashboardReport per_agent).
2162:    out.push_str("\n## §B Role activity\n");
2163:    for (agent, act) in &report.per_agent {
2164:        out.push_str(&format!(
2165:            "  - {}: work_accepted={} work_rejected={} verify_accepted={} verify_rejected={}\n",
2166:            agent,
2167:            act.work_tx_accepted,
2168:            act.work_tx_rejected,
2169:            act.verify_tx_accepted,
2170:            act.verify_tx_rejected,
2171:        ));
2172:    }
2173:
2174:    // §C Market tx counts (from L4 walk).
2175:    out.push_str("\n## §C Market tx counts\n");
2176:    for kind in [
2177:        "TaskOpen", "EscrowLock", "Work", "Verify", "FinalizeReward",
2178:        "EventResolve", "CompleteSetMint", "MarketSeed", "CpmmPool",
2179:        "CpmmSwap", "BuyWithCoinRouter", "CompleteSetRedeem",
2180:        "CompleteSetMerge", "Challenge", "ChallengeResolve",
2181:        "TaskBankruptcy", "TaskExpire", "TerminalSummary",
2182:    ] {
2183:        let n = tx_kind_counts.get(kind).copied().unwrap_or(0);
2184:        out.push_str(&format!("  {kind}: {n}\n"));
2185:    }
2186:    let accepted_work = report
2187:        .per_agent
2188:        .values()
2189:        .map(|a| a.work_tx_accepted as u64)
2190:        .sum::<u64>();
2191:    out.push_str(&format!("  accepted_work_tx_total: {accepted_work}\n"));
2192:
2193:    // §D Top contested nodes — from cpmm pool reserves (read live from
2194:    // sequencer if present; absent here so we approximate from the
2195:    // node_event_seeds map populated by the L4 walk).
2196:    out.push_str("\n## §D Top contested nodes (by seed total μC)\n");
2197:    let mut by_seed: Vec<(&String, &i64)> = node_event_seeds.iter().collect();
2198:    by_seed.sort_by(|a, b| b.1.cmp(a.1));
2199:    if by_seed.is_empty() {
2200:        out.push_str("  (no node-survive pools seeded)\n");
2201:    } else {
2202:        for (event, seed) in by_seed.iter().take(10) {
2203:            out.push_str(&format!("  - {}: {} μC\n", event, seed));
2204:        }
2205:    }
2206:
2207:    // §E Budget burn report (architect §8.5).
2208:    let mmb_genesis_micro: i64 = 5_000_000;
2209:    let pools_skipped_budget: i64 =
2210:        accepted_work as i64 - pools_created as i64;
2211:    out.push_str("\n## §E Budget burn report\n");
2212:    out.push_str(&format!("  pools_created: {}\n", pools_created));
2213:    out.push_str(&format!("  market_seed_total: {} μC\n", market_seed_total_micro));
2214:    out.push_str(&format!("  treasury_budget_start: {} μC (MarketMakerBudget genesis)\n", mmb_genesis_micro));
2215:    out.push_str(&format!(
2216:        "  treasury_budget_end: {} μC (= start - market_seed_total)\n",
2217:        mmb_genesis_micro - market_seed_total_micro
2218:    ));
2219:    out.push_str(&format!(
2220:        "  pools_skipped_budget: {}\n",
2221:        pools_skipped_budget.max(0)
2222:    ));
2223:    out.push_str(&format!("  router_buy_yes: {}\n", router_count_yes));
2224:    out.push_str(&format!("  router_buy_no: {}\n", router_count_no));
2225:
2226:    // §F MarketDecisionTrace summary — scan CAS objects whose schema
2227:    // version sentinel matches `tb_n3.market_decision_trace.v1`.
2228:    let mut outcome_counts: BTreeMap<String, u64> = BTreeMap::new();
2229:    let mut no_trade_breakdown: BTreeMap<String, u64> = BTreeMap::new();
2230:    let mut total_traces: u64 = 0;
2231:    for entry in cas.list_all_cids() {
2232:        let bytes = match cas.get(&entry) {
2233:            Ok(b) => b,
2234:            Err(_) => continue,
2235:        };
2236:        // Trace JSON has a `schema_version` discriminator; skip non-trace
2237:        // AttemptTelemetry objects by checking that prefix.
2238:        let trace: MarketDecisionTrace = match serde_json::from_slice(&bytes) {
2239:            Ok(t) => t,
2240:            Err(_) => continue,
2241:        };
2242:        if trace.schema_version != MarketDecisionTrace::SCHEMA_VERSION {
2243:            continue;
2244:        }
2245:        total_traces += 1;
2246:        match &trace.outcome {
2247:            TraceOutcome::Submitted { .. } => {
2248:                *outcome_counts.entry("submitted".into()).or_insert(0) += 1;
2249:            }
2250:            TraceOutcome::NoTrade { reason, .. } => {
2251:                *outcome_counts.entry("no_trade".into()).or_insert(0) += 1;
2252:                *no_trade_breakdown
2253:                    .entry(reason_label(*reason).into())
2254:                    .or_insert(0) += 1;
2255:            }
2256:            TraceOutcome::Declined => {
2257:                *outcome_counts.entry("declined".into()).or_insert(0) += 1;
2258:            }
2259:        }
2260:    }
2261:    out.push_str("\n## §F MarketDecisionTrace summary\n");
2262:    out.push_str(&format!("  total_traces: {}\n", total_traces));
2263:    for (k, v) in &outcome_counts {
2264:        out.push_str(&format!("  outcome[{}] = {}\n", k, v));
2265:    }
2266:    if !no_trade_breakdown.is_empty() {
2267:        out.push_str("  no_trade reason breakdown:\n");
2268:        let mut sorted: Vec<(&String, &u64)> = no_trade_breakdown.iter().collect();
2269:        sorted.sort_by(|a, b| b.1.cmp(a.1));
2270:        for (reason, n) in sorted {
2271:            out.push_str(&format!("    {} = {}\n", reason, n));
2272:        }
2273:    }
