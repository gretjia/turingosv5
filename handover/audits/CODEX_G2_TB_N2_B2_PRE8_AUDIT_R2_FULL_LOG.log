   481	pub fn canonical_digest(message: &CanonicalMessage) -> [u8; 32] {
   482	    let mut h = Sha256::new();
   483	    h.update(b"turingosv4.system_keypair.v1");
   484	    match message {
   485	        CanonicalMessage::RejectedAttemptSummary(summary) => {
   486	            h.update(b"RejectedAttemptSummary");
   487	            update_len_prefixed(&mut h, summary.run_id.as_bytes());
   488	            update_len_prefixed(&mut h, summary.attempt_id.as_bytes());
   489	            update_len_prefixed(&mut h, summary.failure_class.as_bytes());
   490	            h.update(summary.summary_hash);
   491	        }
   492	        CanonicalMessage::TerminalSummarySigning(digest) => {
   493	            h.update(b"TerminalSummarySigning");
   494	            h.update(digest);
   495	        }
   496	        CanonicalMessage::FinalizeRewardSigning(digest) => {
   497	            h.update(b"FinalizeRewardSigning");
   498	            h.update(digest);
   499	        }
   500	        CanonicalMessage::TaskExpireSigning(digest) => {
   501	            h.update(b"TaskExpireSigning");
   502	            h.update(digest);
   503	        }
   504	        CanonicalMessage::EpochRotationProof(proof) => {
   505	            h.update(b"EpochRotationProof");
   506	            h.update(proof.old_epoch.get().to_be_bytes());
   507	            h.update(proof.new_epoch.get().to_be_bytes());
   508	            h.update(proof.old_pubkey.as_bytes());
   509	            h.update(proof.new_pubkey.as_bytes());
   510	            h.update(proof.signed_at_unix.to_be_bytes());
   511	        }
   512	        CanonicalMessage::LedgerEntrySigning(digest) => {
   513	            h.update(b"LedgerEntrySigning");
   514	            h.update(digest);
   515	        }
   516	        CanonicalMessage::ChallengeResolveSigning(digest) => {
   517	            h.update(b"ChallengeResolveSigning");
   518	            h.update(digest);
   519	        }
   520	        CanonicalMessage::TaskBankruptcySigning(digest) => {
   521	            h.update(b"TaskBankruptcySigning");
   522	            h.update(digest);
   523	        }
   524	        CanonicalMessage::EventResolveSigning(digest) => {
   525	            h.update(b"EventResolveSigning");
   526	            h.update(digest);
   527	        }
   528	    }
   529	    h.finalize().into()
