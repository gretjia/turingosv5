   448	// ════════════════════════════════════════════════════════════════════════════
   449	// SG-N2-B2.9 — R2 race-fix binding (Codex G2 R1 Q8 VETO closure 2026-05-11)
   450	// ════════════════════════════════════════════════════════════════════════════
   451	
   452	/// **R2 race-fix binding gate**. R1 audit (Codex G2 2026-05-11 Q8 VETO)
   453	/// surfaced a runtime race condition: the adapter helper polled only
   454	/// `task_markets_t.state == Open` and emitted `EventResolveTx`
   455	/// immediately on observation. Since `FinalizeRewardTx` applies
   456	/// asynchronously after `tb8_emit_finalize_after_verify` returns Ok, the
   457	/// EventResolve construction captured a pre-FinalizeReward
   458	/// `parent_state_root` R_0. Apply-time state_root was R_1 (post-
   459	/// FinalizeReward apply) → dispatch Step-0 parent-root mismatch →
   460	/// `StaleParent` L4.E `stale_parent_root`. Smoke evidence:
   461	/// `handover/evidence/stage_b3_smoke_b2_20260511T012401Z/`
   462	/// `deepseek-v4-flash/seed1/rep1/P002_aime_1983_p2/runtime_repo/rejections.jsonl:9`.
   463	///
   464	/// R2 fix: caller passes `verify_tx_id`; adapter derives `claim_id =
   465	/// "claim-{verify_tx_id}"` (mirrors tb8 helper) and polls
   466	/// `claims_t[claim_id].status == Finalized` ALONGSIDE the existing
   467	/// `task_markets_t.state == Open` poll. The claim status flip is the
   468	/// witness that FinalizeReward dispatch arm has applied (advancing
   469	/// state_root), so the subsequent emit_system_tx captures the post-
   470	/// FinalizeReward state_root.
   471	///
   472	/// This gate verbatim-binds the R2 fix: source-grep that the helper
   473	/// signature accepts `verify_tx_id: &TxId` AND polls `claims_t` AND
   474	/// matches on `ClaimStatus::Finalized`. Catches silent revert to R1
   475	/// shape.
   476	#[test]
   477	fn sg_n2_b2_9_adapter_polls_claim_finalized_before_emit_r2() {
   478	    let adapter_src = std::fs::read_to_string("src/runtime/adapter.rs")
   479	        .expect("adapter.rs present");
   480	
   481	    // R2 signature: helper accepts verify_tx_id parameter.
   482	    assert!(
   483	        adapter_src.contains("verify_tx_id: &TxId"),
   484	        "src/runtime/adapter.rs `tb_n2_emit_event_resolve_after_finalize` must accept \
   485	         `verify_tx_id: &TxId` parameter (R2 race fix per Codex G2 R1 Q8 VETO closure)",
   486	    );
   487	
   488	    // R2 body: derives claim_id from verify_tx_id (mirrors tb8 helper).
   489	    assert!(
   490	        adapter_src.contains("claim_id_inner = TxId(format!(\"claim-{}\", verify_tx_id.0))"),
   491	        "adapter helper must derive claim_id from verify_tx_id (mirrors tb8 helper's claim_id_inner pattern; R2 race fix)",
   492	    );
   493	
   494	    // R2 body: polls claims_t (not just task_markets_t).
   495	    assert!(
   496	        adapter_src.contains("economic_state_t\n                .claims_t\n                .0\n                .get(&claim_id_inner)")
   497	            || adapter_src.contains(".claims_t.0.get(&claim_id_inner)"),
   498	        "adapter helper must poll claims_t for the claim_id_inner status (R2 race fix)",
   499	    );
   500	
   501	    // R2 body: matches on ClaimStatus::Finalized as the apply-witness.
   502	    assert!(
   503	        adapter_src.contains("ClaimStatus::Finalized"),
   504	        "adapter helper must require `claim.status == ClaimStatus::Finalized` as the FinalizeReward-applied witness (R2 race fix)",
   505	    );
   506	
   507	    // R2 body: combined gate — both claim_finalized AND task Open must hold.
   508	    assert!(
   509	        adapter_src.contains("claim_finalized") && adapter_src.contains("both_ready"),
   510	        "adapter helper must use a combined gate (`both_ready = claim_finalized && task Open`) before emit (R2 race fix)",
   511	    );
   512	
   513	    // Evaluator call sites must pass &vid (verify_tx_id reference).
   514	    let evaluator_src = std::fs::read_to_string(
   515	        "experiments/minif2f_v4/src/bin/evaluator.rs",
   516	    )
   517	    .expect("evaluator.rs present");
   518	    let r2_call_hits = evaluator_src
   519	        .matches("tb_n2_emit_event_resolve_after_finalize(\n                                                    &bundle.sequencer, b2_task_id.clone(), &vid,")
   520	        .count();
   521	    assert!(
   522	        r2_call_hits >= 2,
   523	        "evaluator.rs must invoke `tb_n2_emit_event_resolve_after_finalize` with `&vid` as 3rd arg at BOTH full-proof + per-tactic OMEGA exits (R2 race fix). Found {} R2-shape occurrences.",
   524	        r2_call_hits,
   525	    );
   526	}
