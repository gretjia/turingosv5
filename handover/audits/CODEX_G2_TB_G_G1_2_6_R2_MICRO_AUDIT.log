     1	#!/usr/bin/env bash
     2	# TB-G G1.2-6 / G1.2-7 — chain-continuous batch runner (Option B+ canonical).
     3	#
     4	# Drives `batch_evaluator` (G1.2-3) which spawns the existing `evaluator`
     5	# subprocess once per problem, sharing ONE `runtime_repo/` + ONE `cas/` +
     6	# ONE genesis_report across the batch. Subprocess resume is mandatory for
     7	# every task at task_index > 0 per architect Option B+ ruling §1.
     8	#
     9	# Authority:
    10	#   - architect 2026-05-11 Option B+ orchestration ruling
    11	#     `handover/directives/2026-05-11_TB_G_G1_2_OPTION_B_PLUS_RULING.md`
    12	#     (§1 canonical orchestration + §3.1 ResumePreflight + §3.2
    13	#     ChainTapeLease + §3.3 BatchContinuationManifest + §3.4
    14	#     persistence evidence + §3.5 halt-and-record)
    15	#   - charter §1 G1.2-6 / G1.2-7 ship-gate rows
    16	#   - parent G1.1 §8 packet ship-condition (b) sets the precedent
    17	#     evidence shape (handover/evidence/g_phase_g1_1_smoke_*/)
    18	#
    19	# Per-task evidence shape (sibling of G1.1 smoke + Stage B3):
    20	#   <RUN_DIR>/P<NN>_<problem>/
    21	#     ├── evaluator.stdout    (PPUT_RESULT JSON line + diagnostics)
    22	#     └── evaluator.stderr    (full subprocess stderr)
    23	#
    24	# Run-level artifacts:
    25	#   <RUN_DIR>/runtime_repo/         (shared chain across all tasks)
    26	#   <RUN_DIR>/cas/                  (shared CAS across all tasks)
    27	#   <RUN_DIR>/BatchContinuationManifest.json   (G1.2-4; written by batch_evaluator)
    28	#   <RUN_DIR>/PROBLEMS.txt           (canonical problem list for replay)
    29	#   <RUN_DIR>/G_PHASE_BATCH_MANIFEST.json   (this script; pinning batch-id + git HEAD + model + proxy)
    30	#   <RUN_DIR>/aggregate_verdict.json   (audit_tape over shared runtime_repo + cas)
    31	#   <RUN_DIR>/audit_tape.stderr
    32	#   <RUN_DIR>/run_log.txt              (per-task summary line)
    33	#
    34	# Usage:
    35	#   bash scripts/run_g_phase_batch.sh <run_tag> <problem_set>
    36	#
    37	# Args:
    38	#   run_tag       — output dir suffix; final dir is handover/evidence/<run_tag>/.
    39	#                   Recommended:
    40	#                     g_phase_g1_2_mini_<TS>  (G1.2-6 3-task)
    41	#                     g_phase_g1_2_full_<TS>  (G1.2-7 9-task)
    42	#   problem_set   — one of:
    43	#                     mini   — first 3 of the TB-N3 Phase 2 problem set
    44	#                     full   — full 9-problem TB-N3 Phase 2 set
    45	#                     <path> — explicit problems file (one basename per line)
    46	#
    47	# Env (override-able):
    48	#   LLM_PROXY_URL          — default http://localhost:8080 (matches G1.1 smoke)
    49	#   ACTIVE_MODEL           — default deepseek-chat
    50	#   MINIF2F_DIR            — default /home/zephryj/projects/turingosv3/experiments/minif2f_data_lean4
    51	#   PER_PROBLEM_TIMEOUT_S  — default 900 (15 min)
    52	#   TURINGOS_TB_N3_AUTO_MARKET — default 1 (auto-emit node-survive markets)
    53	
    54	set -uo pipefail
    55	
    56	# ── Argument parsing ────────────────────────────────────────────────────────
    57	
    58	if [[ $# -lt 2 ]]; then
    59	    echo "ERROR: usage: $0 <run_tag> <problem_set:mini|full|<path>>" >&2
    60	    exit 2
    61	fi
    62	
    63	RUN_TAG="$1"
    64	PROBLEM_SET="$2"
    65	
    66	# ── Paths and constants ─────────────────────────────────────────────────────
    67	
    68	SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    69	PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
    70	RUN_DIR="$PROJECT_ROOT/handover/evidence/$RUN_TAG"
    71	MINIF2F_DIR="${MINIF2F_DIR:-/home/zephryj/projects/turingosv3/experiments/minif2f_data_lean4}"
    72	ACTIVE_MODEL="${ACTIVE_MODEL:-deepseek-chat}"
    73	LLM_PROXY_URL="${LLM_PROXY_URL:-http://localhost:8080}"
    74	PER_PROBLEM_TIMEOUT_S="${PER_PROBLEM_TIMEOUT_S:-900}"
    75	
    76	# ── Source .env (DeepSeek key) ──────────────────────────────────────────────
    77	
    78	if [[ -f "$PROJECT_ROOT/.env" ]]; then
    79	    set -a
    80	    # shellcheck disable=SC1091
    81	    . "$PROJECT_ROOT/.env"
    82	    set +a
    83	fi
    84	: "${DEEPSEEK_API_KEY:?DEEPSEEK_API_KEY not set; populate .env first}"
    85	
    86	# ── Problem set resolution ──────────────────────────────────────────────────
    87	
    88	# Canonical TB-N3 Phase 2 9-problem set (matches
    89	# handover/evidence/tb_n3_phase2_2026-05-11T06-58-07Z/tbc0_problems.txt).
    90	TBN3_PHASE2_PROBLEMS=(
    91	    mathd_algebra_107
    92	    mathd_algebra_125
    93	    mathd_algebra_141
    94	    mathd_algebra_113
    95	    mathd_algebra_114
    96	    mathd_numbertheory_1124
    97	    numbertheory_2pownm1prime_nprime
    98	    aime_1983_p1
    99	    aime_1984_p1
   100	)
   101	
   102	PROBLEMS_FILE="$RUN_DIR/PROBLEMS.txt"
   103	mkdir -p "$RUN_DIR"
   104	
   105	case "$PROBLEM_SET" in
   106	    mini)
   107	        printf '%s\n' "${TBN3_PHASE2_PROBLEMS[@]:0:3}" > "$PROBLEMS_FILE"
   108	        ;;
   109	    full)
   110	        printf '%s\n' "${TBN3_PHASE2_PROBLEMS[@]}" > "$PROBLEMS_FILE"
   111	        ;;
   112	    *)
   113	        if [[ -f "$PROBLEM_SET" ]]; then
   114	            cp "$PROBLEM_SET" "$PROBLEMS_FILE"
   115	        else
   116	            echo "ERROR: PROBLEM_SET '$PROBLEM_SET' is not 'mini', 'full', nor an existing file" >&2
   117	            exit 2
   118	        fi
   119	        ;;
   120	esac
   121	
   122	PROBLEM_COUNT=$(grep -cvE '^(#|$)' "$PROBLEMS_FILE")
   123	[[ "$PROBLEM_COUNT" -ge 1 ]] || { echo "ERROR: PROBLEMS.txt is empty" >&2; exit 2; }
   124	
   125	# ── Pre-loop validation ─────────────────────────────────────────────────────
   126	
   127	echo "════════════════════════════════════════════════════════════════════════"
   128	echo "TB-G G1.2 chain-continuous batch (Option B+ canonical)"
   129	echo "════════════════════════════════════════════════════════════════════════"
   130	echo "RUN_TAG          = $RUN_TAG"
   131	echo "RUN_DIR          = $RUN_DIR"
   132	echo "PROBLEM_SET      = $PROBLEM_SET  ($PROBLEM_COUNT tasks)"
   133	echo "ACTIVE_MODEL     = $ACTIVE_MODEL"
   134	echo "LLM_PROXY_URL    = $LLM_PROXY_URL"
   135	echo "MINIF2F_DIR      = $MINIF2F_DIR"
   136	echo "PER_PROB_TIMEOUT = ${PER_PROBLEM_TIMEOUT_S}s"
   137	echo
   138	
   139	# Tree status — non-evidence drift is a /runner-preflight Stage-1 failure
   140	# per CR-18B.9. Backstop here in case the caller did not invoke the gate.
   141	if [[ -n "$(cd "$PROJECT_ROOT" && git status --porcelain | grep -vE '^\?\? handover/evidence/' | head -1)" ]]; then
   142	    echo "WARNING: working tree has non-evidence changes; /runner-preflight Stage 1 normally rejects this." >&2
   143	    if [[ "${TURINGOS_G_PHASE_DIRTY_OK:-0}" != "1" ]]; then
   144	        echo "  Set TURINGOS_G_PHASE_DIRTY_OK=1 to override (smoke testing only)." >&2
   145	        exit 3
   146	    fi
   147	fi
   148	
   149	# Disk free check — G1.2-7 9-task batches write multi-GB to runtime_repo +
   150	# CAS. 20G free is the architect-stated minimum.
   151	DISK_FREE_G=$(df -BG --output=avail "$PROJECT_ROOT" | tail -1 | tr -dc '0-9')
   152	if [[ "${DISK_FREE_G:-0}" -lt 20 ]]; then
   153	    echo "WARNING: only ${DISK_FREE_G}G free on $(df -h --output=target "$PROJECT_ROOT" | tail -1); architect minimum is 20G." >&2
   154	    if [[ "${TURINGOS_G_PHASE_LOW_DISK_OK:-0}" != "1" ]]; then
   155	        echo "  Set TURINGOS_G_PHASE_LOW_DISK_OK=1 to override (smoke only)." >&2
   156	        exit 4
   157	    fi
   158	fi
   159	
   160	# LLM proxy health probe.
   161	if ! curl -sS --max-time 5 "$LLM_PROXY_URL/health" | grep -q '"status": "ok"'; then
   162	    echo "ERROR: LLM proxy $LLM_PROXY_URL/health not OK" >&2
   163	    exit 5
   164	fi
   165	
   166	GIT_HEAD="$(cd "$PROJECT_ROOT" && git rev-parse HEAD 2>/dev/null || echo unknown)"
   167	RUN_TIMESTAMP_UTC="$(date -u +%Y-%m-%dT%H-%M-%SZ)"
   168	BATCH_ID="${RUN_TAG}_${GIT_HEAD:0:7}"
   169	
   170	# ── Build release binaries ──────────────────────────────────────────────────
   171	
   172	echo "[build] cargo build --release -p minif2f_v4 --bin evaluator --bin batch_evaluator -p turingosv4 --bin audit_tape --bin tb_g_persistence_report"
   173	(cd "$PROJECT_ROOT" && cargo build --release -p minif2f_v4 --bin evaluator --bin batch_evaluator -p turingosv4 --bin audit_tape --bin tb_g_persistence_report 2>&1 | tail -5)
   174	EVALUATOR="$PROJECT_ROOT/target/release/evaluator"
   175	BATCH_EVALUATOR="$PROJECT_ROOT/target/release/batch_evaluator"
   176	AUDIT_TAPE="$PROJECT_ROOT/target/release/audit_tape"
   177	PERSISTENCE_REPORT="$PROJECT_ROOT/target/release/tb_g_persistence_report"
   178	for b in "$EVALUATOR" "$BATCH_EVALUATOR" "$AUDIT_TAPE" "$PERSISTENCE_REPORT"; do
   179	    [[ -x "$b" ]] || { echo "ERROR: binary not built: $b" >&2; exit 6; }
   180	done
   181	
   182	# ── Manifest header ─────────────────────────────────────────────────────────
   183	
   184	cat > "$RUN_DIR/G_PHASE_BATCH_MANIFEST.json" <<EOF
   185	{
   186	  "tb_id": "TB-G",
   187	  "atom": "G1.2-6/7",
   188	  "phase": "G1.2 chain-continuous batch (Option B+ canonical)",
   189	  "ruling": "handover/directives/2026-05-11_TB_G_G1_2_OPTION_B_PLUS_RULING.md",
   190	  "run_tag": "$RUN_TAG",
   191	  "batch_id": "$BATCH_ID",
   192	  "problem_count": $PROBLEM_COUNT,
   193	  "problem_set": "$PROBLEM_SET",
   194	  "shared_runtime_repo": "$RUN_DIR/runtime_repo",
   195	  "shared_cas": "$RUN_DIR/cas",
   196	  "active_model": "$ACTIVE_MODEL",
   197	  "llm_proxy_url": "$LLM_PROXY_URL",
   198	  "minif2f_dir": "$MINIF2F_DIR",
   199	  "per_problem_timeout_s": $PER_PROBLEM_TIMEOUT_S,
   200	  "git_head": "$GIT_HEAD",
   201	  "run_timestamp_utc": "$RUN_TIMESTAMP_UTC",
   202	  "resume_semantic": "task_0 = fresh genesis; task_k>0 = TURINGOS_CHAINTAPE_RESUME=1 via batch_evaluator (Option B+ §1)",
   203	  "halt_on": "any subprocess exits non-zero (architect §3.5 halt-and-record)"
   204	}
   205	EOF
   206	
   207	# ── Run batch_evaluator ─────────────────────────────────────────────────────
   208	
   209	echo
   210	echo "[batch_evaluator] launching $PROBLEM_COUNT-task batch ($BATCH_ID)"
   211	echo "[batch_evaluator] runtime_repo=$RUN_DIR/runtime_repo cas=$RUN_DIR/cas"
   212	START_TS=$(date +%s)
   213	
   214	export MINIF2F_DIR
   215	export ACTIVE_MODEL
   216	export LLM_PROXY_URL
   217	export TURINGOS_TB_N3_AUTO_MARKET="${TURINGOS_TB_N3_AUTO_MARKET:-1}"
   218	
   219	# batch_evaluator owns the per-subprocess env. It sets
   220	# TURINGOS_CHAINTAPE_PATH / TURINGOS_CAS_PATH / TURINGOS_RUN_ID /
   221	# TURINGOS_CHAINTAPE_RESUME (the last only for task_k > 0). It does NOT
   222	# set ACTIVE_MODEL / LLM_PROXY_URL / MINIF2F_DIR — those inherit from
   223	# this script's exports above.
   224	
   225	"$BATCH_EVALUATOR" \
   226	    --runtime-repo "$RUN_DIR/runtime_repo" \
   227	    --cas "$RUN_DIR/cas" \
   228	    --batch-id "$BATCH_ID" \
   229	    --problems-file "$PROBLEMS_FILE" \
   230	    --model "$ACTIVE_MODEL" \
   231	    --n-agents 10 \
   232	    --condition n1 \
   233	    --out-dir "$RUN_DIR" \
   234	    --evaluator-bin "$EVALUATOR" \
   235	    --minif2f-dir "$MINIF2F_DIR/MiniF2F/Test" \
   236	    --llm-proxy-url "$LLM_PROXY_URL" \
   237	    --per-task-timeout-s "$PER_PROBLEM_TIMEOUT_S" \
   238	    2>&1 | tee "$RUN_DIR/batch_evaluator.log"
   239	BATCH_EXIT=${PIPESTATUS[0]}
   240	
   241	ELAPSED=$(($(date +%s) - START_TS))
   242	echo "[batch_evaluator] exit_code=$BATCH_EXIT elapsed=${ELAPSED}s"
   243	
   244	# ── Aggregate audit_tape over the shared chain ──────────────────────────────
   245	
   246	echo
   247	echo "[audit_tape] running over shared runtime_repo + cas"
   248	( cd "$PROJECT_ROOT" && "$AUDIT_TAPE" \
   249	    --runtime-repo "$RUN_DIR/runtime_repo" \
   250	    --cas-dir "$RUN_DIR/cas" \
   251	    --agent-pubkeys "$RUN_DIR/runtime_repo/agent_pubkeys.json" \
   252	    --pinned-pubkeys "$RUN_DIR/runtime_repo/pinned_pubkeys.json" \
   253	    --genesis "$PROJECT_ROOT/genesis_payload.toml" \
   254	    --constitution "$PROJECT_ROOT/constitution.md" \
   255	    --alignment-dir "$PROJECT_ROOT/handover/alignment" \
   256	    --out "$RUN_DIR/aggregate_verdict.json" \
   257	    ) 2> "$RUN_DIR/audit_tape.stderr"
   258	AUDIT_EXIT=$?
   259	
   260	VERDICT="$(grep -E '"verdict"' "$RUN_DIR/aggregate_verdict.json" 2>/dev/null | head -1 | sed -E 's/.*"verdict": *"([^"]+)".*/\1/')"

