   112	        &spec.batch_id,
   113	        &prior.end_head_t_hex,
   114	    )
   115	    .map_err(|e| BoundaryError::Lease(e.to_string()))?;
   116	    eprintln!(
   117	        "batch_orchestrator: task_index={task_index} ChainTapeLease ACQUIRED \
   118	         (holder_pid={}, batch_id={}, start_head={})",
   119	        std::process::id(),
   120	        spec.batch_id,
   121	        prior.end_head_t_hex,
   122	    );
   123	
   124	    // Re-snapshot under lock for the state-root claim that preflight
   125	    // will verify.
   126	    let (head_hex, state_root_hex, chain_length) =
   127	        snapshot_head_t(&spec.runtime_repo).map_err(BoundaryError::Snapshot)?;
   128	
   129	    let contract = ResumeContract {
   130	        runtime_repo: spec.runtime_repo.clone(),
   131	        cas_path: spec.cas_path.clone(),
   132	        expected_head_t_hex: head_hex.clone(),
   133	        expected_state_root_hex: state_root_hex.clone(),
   134	        expected_chain_length: chain_length,
   135	        batch_id: spec.batch_id.clone(),
   136	        task_index,
   137	        agent_pubkeys_path: spec.runtime_repo.join("agent_pubkeys.json"),
   138	        pinned_pubkeys_path: spec.runtime_repo.join("pinned_pubkeys.json"),
   139	        genesis_report_path: spec.runtime_repo.join("genesis_report.json"),
   140	    };
   141	
   142	    match preflight_check(&contract) {
   143	        PreflightVerdict::Ok => {
   144	            eprintln!(
   145	                "batch_orchestrator: task_index={task_index} ResumePreflight::Ok \
   146	                 (head={head_hex} state_root={state_root_hex} chain_length={chain_length}) \
   147	                 → BoundaryPrep::Resume"
   148	            );
   149	            Ok(BoundaryPrep::Resume {
   150	                lease,
   151	                start_head_t_hex: head_hex,
   152	                start_chain_length: chain_length,
   153	            })
   154	        }
   155	        PreflightVerdict::Fail { failure } => {
   156	            // Drop the lease before returning the error so the next
   157	            // attempt sees a clean state.
   158	            drop(lease);
   159	            eprintln!(
   160	                "batch_orchestrator: task_index={task_index} ResumePreflight::Fail \
   234	    boundary: &BoundaryPrep,
   235	) -> Vec<(String, String)> {
   236	    let mut env = vec![
   237	        (
   238	            "TURINGOS_CHAINTAPE_PATH".to_string(),
   239	            spec.runtime_repo.to_string_lossy().into_owned(),
   240	        ),
   241	        (
   242	            "TURINGOS_CAS_PATH".to_string(),
   243	            spec.cas_path.to_string_lossy().into_owned(),
   244	        ),
   245	        ("ACTIVE_MODEL".to_string(), spec.model.clone()),
   246	        (
   247	            "LLM_PROXY_URL".to_string(),
   248	            spec.llm_proxy_url.clone(),
   249	        ),
   250	        (
   251	            "TURINGOS_RUN_ID".to_string(),
   252	            format!("{}_t{:03}", spec.batch_id, task_index),
   253	        ),
   254	    ];
   255	    // Architect §1: for task_0 the resume flag MUST be unset; for
   256	    // task_k>0 it MUST be "1". Default-deny posture preserved.
   257	    if matches!(boundary, BoundaryPrep::Resume { .. }) {
   258	        env.push(("TURINGOS_CHAINTAPE_RESUME".to_string(), "1".to_string()));
   259	    }
   260	    env
   261	}
