   114	/// TRACE_MATRIX § 3 orphan (TB-G G1.2-4 2026-05-11; Option B+ §3.3):
   115	/// chain-continuity verifier. Returns Ok iff:
   116	/// 1. `tasks[0].start_head_t_hex == initial_head_t_hex` (the batch
   117	///    actually started from the recorded genesis)
   118	/// 2. `tasks[k+1].start_head_t_hex == tasks[k].end_head_t_hex`
   119	///    for every consecutive pair.
   120	pub fn replay_continuity(
   121	    manifest: &BatchContinuationManifest,
   122	) -> Result<(), ContinuityFailure> {
   123	    if let Some(first) = manifest.tasks.first() {
   124	        if first.start_head_t_hex != manifest.initial_head_t_hex {
   125	            return Err(ContinuityFailure::FirstTaskDoesNotMatchInitial {
   126	                initial_head_t_hex: manifest.initial_head_t_hex.clone(),
   127	                first_task_start: first.start_head_t_hex.clone(),
   128	            });
   129	        }
   130	    }
   131	    for (i, pair) in manifest.tasks.windows(2).enumerate() {
   132	        if pair[1].start_head_t_hex != pair[0].end_head_t_hex {
   133	            return Err(ContinuityFailure::Gap {
   134	                at_pair_index: i,
   135	                task_k_index: pair[0].task_index,
   136	                task_k_end: pair[0].end_head_t_hex.clone(),
   137	                task_k_plus_1_index: pair[1].task_index,
   138	                task_k_plus_1_start: pair[1].start_head_t_hex.clone(),
   139	            });
   140	        }
   141	    }
   142	    Ok(())
   143	}
