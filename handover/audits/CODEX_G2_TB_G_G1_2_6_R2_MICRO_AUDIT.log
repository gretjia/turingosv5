fn total_balance_micro(q: &QState) -> i64 {
    q.economic_state_t
        .balances_t
        .0
        .values()
        .map(|c| c.micro_units())
        .fold(0i64, i64::saturating_add)
}

fn total_collateral_micro(q: &QState) -> i64 {
    q.economic_state_t
        .conditional_collateral_t
        .0
        .values()
        .map(|c| c.micro_units())
        .fold(0i64, i64::saturating_add)
}

fn autopsy_capsule_total(q: &QState) -> usize {
    q.economic_state_t
        .agent_autopsies_t
        .0
        .values()
        .map(|v| v.len())
        .sum()
}

