   488	/// TRACE_MATRIX § 3 orphan (TB-G G1.2-5 2026-05-11; Option B+ §3.4):
   489	/// `replay_task_end_snapshots_from_disk` — replays the on-disk
   490	/// `runtime_repo` + `cas` for each task boundary recorded in
   491	/// `manifest.tasks` and returns `(initial_q, per_task_end_q)` ready
   492	/// for `bind_persistence`. Used by the `tb_g_persistence_report`
   493	/// binary (G1.2-6/7 evidence enricher; Codex Q6 closure).
   494	///
   495	/// Reads `pinned_pubkeys.json` + `initial_q_state.json` via the same
   496	/// FC2-Boot semantics as `verify_chaintape`. For each task k, slices
   497	/// the chain entries to `[0..tasks[k].end_chain_length]` and re-runs
   498	/// `replay_full_transition` to obtain the post-task `QState`. This
   499	/// is O(N²) in worst case (one full replay per boundary) but
   500	/// negligible for the G1.2 batch sizes (3-9 tasks).
   501	pub fn replay_task_end_snapshots_from_disk(
   502	    runtime_repo_path: &Path,
   503	    cas_path: &Path,
   504	    manifest: &BatchContinuationManifest,
   505	) -> Result<(QState, Vec<QState>), ReplaySnapshotError> {
   506	    // pinned pubkeys
   507	    let pin_path = runtime_repo_path.join("pinned_pubkeys.json");
   508	    let pin_json = std::fs::read_to_string(&pin_path)
   509	        .map_err(|e| ReplaySnapshotError::Io(format!("read {pin_path:?}: {e}")))?;
   510	    let pin_manifest: crate::runtime::PinnedPubkeyManifest = serde_json::from_str(&pin_json)
   511	        .map_err(|e| ReplaySnapshotError::Parse(format!("pinned_pubkeys: {e}")))?;
   512	    let mut pinned = PinnedSystemPubkeys::new();
   513	    for entry in &pin_manifest.pubkeys {
   514	        let bytes = decode_hex_32(&entry.pubkey_hex)?;
   515	        let pubkey = SystemPublicKey::from_bytes(bytes);
   516	        pinned.insert(SystemEpoch::new(entry.epoch), pubkey);
   517	    }
   518	
   519	    // initial QState (fall back to genesis if file absent — matches verify_chaintape)
   520	    let initial_q_path = runtime_repo_path.join("initial_q_state.json");
   521	    let initial_q = if initial_q_path.exists() {
   522	        let s = std::fs::read_to_string(&initial_q_path)
   523	            .map_err(|e| ReplaySnapshotError::Io(format!("read initial_q: {e}")))?;
   524	        serde_json::from_str::<QState>(&s)
   525	            .map_err(|e| ReplaySnapshotError::Parse(format!("initial_q_state: {e}")))?
   526	    } else {
   527	        QState::genesis()
   528	    };
   529	
   530	    // open ledger writer + CAS
   531	    let writer = Git2LedgerWriter::open(runtime_repo_path)
   532	        .map_err(|e| ReplaySnapshotError::Io(format!("open ledger: {e}")))?;
   533	    let chain_len = writer.len();
   534	    let cas_store = CasStore::open(cas_path)
   535	        .map_err(|e| ReplaySnapshotError::Io(format!("open cas: {e}")))?;
   536	
   537	    // pull entries [1..=chain_len] once
   538	    let entries: Vec<LedgerEntry> = (1..=chain_len)
   539	        .map(|t| writer.read_at(t))
   540	        .collect::<Result<Vec<_>, _>>()
   541	        .map_err(|e| ReplaySnapshotError::Io(format!("read entries: {e}")))?;
   542	
   543	    let predicate_registry = PredicateRegistry::new();
   544	    let tool_registry = ToolRegistry::new();
   545	
   546	    let mut per_task: Vec<QState> = Vec::with_capacity(manifest.tasks.len());
   547	    for task in &manifest.tasks {
   548	        let end_idx = task.end_chain_length as usize;
   549	        if end_idx > entries.len() {
   550	            return Err(ReplaySnapshotError::ManifestExceedsChain {
   551	                task_index: task.task_index,
   552	                end_chain_length: task.end_chain_length,
   553	                actual_chain_length: chain_len,
   554	            });
   555	        }
   556	        let prefix = &entries[..end_idx];
   557	        let q = replay_full_transition(
   558	            &initial_q,
   559	            prefix,
   560	            &cas_store,
   561	            &pinned,
   562	            &predicate_registry,
   563	            &tool_registry,
   564	        )
   565	        .map_err(|e| ReplaySnapshotError::Replay {
   566	            task_index: task.task_index,
   567	            detail: format!("{e:?}"),
   568	        })?;
   569	        per_task.push(q);
   570	    }
   571	
   572	    Ok((initial_q, per_task))
   573	}
   574	
   575	fn decode_hex_32(hex: &str) -> Result<[u8; 32], ReplaySnapshotError> {
   576	    if hex.len() != 64 || !hex.chars().all(|c| c.is_ascii_hexdigit()) {
   577	        return Err(ReplaySnapshotError::Parse(format!(
   578	            "pubkey hex must be 64 lowercase hex chars; got {} chars",
   579	            hex.len()
   580	        )));
   581	    }
   582	    let mut out = [0u8; 32];
   583	    for i in 0..32 {
   584	        out[i] = u8::from_str_radix(&hex[i * 2..i * 2 + 2], 16)
   585	            .map_err(|_| ReplaySnapshotError::Parse("bad hex digit".into()))?;
   586	    }
   587	    Ok(out)
   588	}
