   310	
   311	    /// Construct a contract pointed at an empty (uninitialized) repo.
   312	    /// Useful for the missing-path reject tests.
   313	    fn contract_for(tmp: &TempDir, task_index: u64) -> ResumeContract {
   314	        let runtime_repo = tmp.path().join("runtime_repo");
   315	        ResumeContract {
   316	            runtime_repo: runtime_repo.clone(),
   317	            cas_path: tmp.path().join("cas"),
   318	            expected_head_t_hex: String::new(),
   319	            expected_state_root_hex: String::new(),
   320	            expected_chain_length: 0,
   321	            batch_id: "test_batch".into(),
   322	            task_index,
   323	            agent_pubkeys_path: runtime_repo.join("agent_pubkeys.json"),
   324	            pinned_pubkeys_path: runtime_repo.join("pinned_pubkeys.json"),
   325	            genesis_report_path: runtime_repo.join("genesis_report.json"),
   326	        }
   327	    }
   328	
   329	    #[test]
   330	    fn unit_task_index_zero_rejected() {
   331	        let tmp = TempDir::new().expect("tempdir");
   332	        let c = contract_for(&tmp, 0);
   333	        match check(&c) {
   334	            PreflightVerdict::Fail { failure: PreflightFailure::TaskIndexGap { task_index } } => {
   335	                assert_eq!(task_index, 0);
   336	            }
   337	            other => panic!("expected TaskIndexGap, got {other:?}"),
   338	        }
   339	    }
