   239	/// Constitutional Justification: same OPTION_B_PLUS_RULING §3.2.
   240	pub fn read_lease(runtime_repo: &Path) -> Result<Option<ChainTapeLease>, LeaseError> {
   241	    let lease_path = runtime_repo.join(LEASE_FILE);
   242	    if !lease_path.exists() {
   243	        return Ok(None);
   244	    }
   245	    let bytes = fs::read(&lease_path).map_err(LeaseError::Io)?;
   246	    let lease: ChainTapeLease =
   247	        serde_json::from_slice(&bytes).map_err(|e| LeaseError::Parse(e.to_string()))?;
   248	    Ok(Some(lease))
   249	}
   250	
   251	fn write_atomic(target: &Path, lease: &ChainTapeLease) -> Result<(), LeaseError> {
   252	    let parent = target.parent().ok_or_else(|| {
   253	        LeaseError::Io(io::Error::new(
   254	            io::ErrorKind::InvalidInput,
   255	            "lease target has no parent dir",
   256	        ))
   257	    })?;
   258	    let json = serde_json::to_vec_pretty(lease).map_err(|e| LeaseError::Parse(e.to_string()))?;
   259	    let tmp_path = parent.join(format!(
   260	        "{}.tmp.{}",
   261	        LEASE_FILE,
   262	        std::process::id()
   263	    ));
   264	    {
   265	        let mut f = fs::File::create(&tmp_path).map_err(LeaseError::Io)?;
   266	        f.write_all(&json).map_err(LeaseError::Io)?;
   267	        f.sync_all().map_err(LeaseError::Io)?;
   268	    }
   269	    fs::rename(&tmp_path, target).map_err(LeaseError::Io)?;
   270	    Ok(())

