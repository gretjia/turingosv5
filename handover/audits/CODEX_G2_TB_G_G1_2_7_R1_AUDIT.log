   156	                existing.holder_pid, existing.batch_id, existing.acquired_at_unix_s
   157	            ),
   158	            Self::HeadChangedSinceLastAcquire { expected_hex, actual_hex } => write!(
   159	                f,
   160	                "chain tape head changed since acquire: expected={expected_hex} actual={actual_hex}"
   161	            ),
   162	            Self::HolderPidMismatch { expected_pid, actual_pid } => write!(
   163	                f,
   164	                "lease release pid mismatch: expected={expected_pid} actual={actual_pid}"
   165	            ),
   166	            Self::Parse(s) => write!(f, "lease parse error: {s}"),
   167	            Self::Io(e) => write!(f, "lease io error: {e}"),
   168	        }
   169	    }
   170	}
