   592	#[derive(Debug)]
   593	pub enum ReplaySnapshotError {
   594	    Io(String),
   595	    Parse(String),
   596	    Replay {
   597	        task_index: u64,
   598	        detail: String,
   599	    },
   600	    ManifestExceedsChain {
   601	        task_index: u64,
   602	        end_chain_length: u64,
   603	        actual_chain_length: u64,
   604	    },
   605	}
