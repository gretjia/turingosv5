   290	pub fn snapshot_head_t(runtime_repo: &Path) -> Result<(String, String, u64), String> {
   291	    let writer = Git2LedgerWriter::open(runtime_repo)
   292	        .map_err(|e| format!("Git2LedgerWriter::open({runtime_repo:?}): {e}"))?;
   293	    let head_hex = writer.head_commit_oid_hex().unwrap_or_default();
   294	    let len = writer.len();
   295	    let state_root_hex = if len == 0 {
   296	        String::new()
   297	    } else {
   298	        let entry = writer
   299	            .read_at(len)
   300	            .map_err(|e| format!("read_at({len}): {e}"))?;
   301	        hash_to_hex(&entry.resulting_state_root)
   302	    };
   303	    Ok((head_hex, state_root_hex, len))
   304	}
   305	
