   112	        &spec.batch_id,
   113	        &prior.end_head_t_hex,
   114	    )
   115	    .map_err(|e| BoundaryError::Lease(e.to_string()))?;
   116	    eprintln!(
   117	        "batch_orchestrator: task_index={task_index} ChainTapeLease ACQUIRED \
   118	         (holder_pid={}, batch_id={}, start_head={})",
   119	        std::process::id(),
   120	        spec.batch_id,
   121	        prior.end_head_t_hex,
   122	    );
   123	
   124	    // Re-snapshot under lock for the state-root claim that preflight
   125	    // will verify.
   126	    let (head_hex, state_root_hex, chain_length) =
   127	        snapshot_head_t(&spec.runtime_repo).map_err(BoundaryError::Snapshot)?;
   128	
   129	    let contract = ResumeContract {
   130	        runtime_repo: spec.runtime_repo.clone(),
   131	        cas_path: spec.cas_path.clone(),
   132	        expected_head_t_hex: head_hex.clone(),
   133	        expected_state_root_hex: state_root_hex.clone(),
   134	        expected_chain_length: chain_length,
   135	        batch_id: spec.batch_id.clone(),
   136	        task_index,
   137	        agent_pubkeys_path: spec.runtime_repo.join("agent_pubkeys.json"),
   138	        pinned_pubkeys_path: spec.runtime_repo.join("pinned_pubkeys.json"),
   139	        genesis_report_path: spec.runtime_repo.join("genesis_report.json"),
   140	    };
