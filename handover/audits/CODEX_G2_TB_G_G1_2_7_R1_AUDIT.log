   306	            n = per_task.len(),
   307	            initial_n = initial.balances_distinct_agents,
   308	            final_n = per_task
   309	                .last()
   310	                .map(|t| t.balances_distinct_agents)
   311	                .unwrap_or(0),
   312	        ))
   313	    } else {
   314	        FieldVerdict::Empty(
   315	            "balances_total + distinct_agents unchanged across batch".into(),
   316	        )
   317	    }
   318	}
