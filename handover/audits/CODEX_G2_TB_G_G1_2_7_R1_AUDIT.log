   196	            return Err(LeaseError::AlreadyHeld { existing: current });
   197	        }
   198	        // Stale lock — holder pid is dead. Force-release.
   199	        let _ = fs::remove_file(&lease_path);
   200	    }
   201	
   202	    // HEAD continuity check against the live `refs/transitions/main` /
   203	    // C2 `refs/chaintape/l4`. Empty `expected_head_t_hex` means "I
   204	    // don't care" (test scaffolding / fresh-genesis lease at task_0).
   205	    if !expected_head_t_hex.is_empty() {
   206	        let actual = snapshot_head_hex(runtime_repo)?;
   207	        if actual != expected_head_t_hex {
   208	            return Err(LeaseError::HeadChangedSinceLastAcquire {
   209	                expected_hex: expected_head_t_hex.to_string(),
   210	                actual_hex: actual,
   211	            });
   212	        }
   213	    }
   214	
   215	    let holder_pid = std::process::id() as i32;
   216	    let acquired_at_unix_s = SystemTime::now()
   217	        .duration_since(UNIX_EPOCH)
   218	        .map(|d| d.as_secs() as i64)
   219	        .unwrap_or(0);
   220	    let lease = ChainTapeLease {
   221	        holder_pid,
   222	        batch_id: batch_id.to_string(),
   223	        start_head_t_hex: expected_head_t_hex.to_string(),
   224	        acquired_at_unix_s,
   225	    };
   226	    write_atomic(&lease_path, &lease)?;
   227	
   228	    Ok(LeaseGuard {
   229	        runtime_repo: runtime_repo.to_path_buf(),
   230	        holder_pid,
   231	        released: false,
   232	    })
   233	}
