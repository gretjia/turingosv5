   181	/// Justification: same OPTION_B_PLUS_RULING §3.2 "only one writer
   182	/// can advance HEAD_t at a time".
   183	pub fn acquire(
   184	    runtime_repo: &Path,
   185	    batch_id: &str,
   186	    expected_head_t_hex: &str,
   187	) -> Result<LeaseGuard, LeaseError> {
   188	    fs::create_dir_all(runtime_repo).map_err(LeaseError::Io)?;
   189	    let lease_path = runtime_repo.join(LEASE_FILE);
   190	
   191	    if lease_path.exists() {
   192	        let bytes = fs::read(&lease_path).map_err(LeaseError::Io)?;
   193	        let current: ChainTapeLease =
   194	            serde_json::from_slice(&bytes).map_err(|e| LeaseError::Parse(e.to_string()))?;
