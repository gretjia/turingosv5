   286	                "task[{k}] (problem={problem}) balances_t empty after a \
   287	                 prior non-empty snapshot (kill-criterion #1)",
   288	                problem = t.problem_id
   289	            ));
   290	        }
   291	        if t.balances_distinct_agents > 0 {
   292	            saw_non_empty = true;
   293	        }
   294	    }
   295	    let final_total = per_task.last().map(|t| t.balances_total_micro).unwrap_or(0);
