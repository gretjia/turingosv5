   643	// § 2.5 Canonical serialization (bincode v2; STATE_TRANSITION_SPEC § 2.5)
   644	// ────────────────────────────────────────────────────────────────────────────
   645	
   646	/// `bincode::config` used for the canonical `LedgerEntry` wire format.
   647	///
   648	/// **Frozen choices** (per STATE_TRANSITION_SPEC § 2.5):
   649	/// - **Big-endian** byte order (network order; deterministic across platforms).
   650	/// - **Fixed-int encoding** (no varint; fixed-width for byte-stable round-trip).
   651	/// - **`BTreeMap` keys**: bincode iterates the map in serde-supplied order; we
   652	///   only ever encode `BTreeMap` (sorted by construction) so key order is lex.
   653	/// - **No padding, no implicit alignment.**
   654	fn bincode_canonical_config() -> impl bincode::config::Config {
   655	    bincode::config::standard()
   656	        .with_big_endian()
   657	        .with_fixed_int_encoding()
   658	}
   659	
   660	/// Canonical encode any serde-Serialize value to bytes (CO1.7 wire format).
   661	/// Used by `Git2LedgerWriter` for commit-message bodies and by future callers
   662	/// needing byte-stable signatures over typed payloads.
   663	pub fn canonical_encode<T: Serialize>(value: &T) -> Result<Vec<u8>, CanonicalCodecError> {
   664	    bincode::serde::encode_to_vec(value, bincode_canonical_config())
   665	        .map_err(|e| CanonicalCodecError::Encode(e.to_string()))
   666	}
   667	
   668	/// Canonical decode the inverse of `canonical_encode`. Returns the value plus
   669	/// the number of bytes consumed (entire input must be consumed for a clean decode).
   670	pub fn canonical_decode<T: serde::de::DeserializeOwned>(
   671	    bytes: &[u8],
   672	) -> Result<T, CanonicalCodecError> {
   673	    let (value, consumed) =
   674	        bincode::serde::decode_from_slice::<T, _>(bytes, bincode_canonical_config())
   675	            .map_err(|e| CanonicalCodecError::Decode(e.to_string()))?;

