   668	/// TB-G G1.1 (architect §8 SIGNED 2026-05-11; packet §2 resume branch):
   669	/// reconstruct the (keypair, epoch, pinned pubkeys, seed QState,
   670	/// chain_length) tuple consumed by `build_chaintape_sequencer_with_initial_q`
   671	/// when resuming a non-empty `refs/transitions/main` chain.
   672	///
   673	/// Steps (FC2 Boot constitutional alignment per CLAUDE.md §3.2 +
   674	/// §4.1 G-009 Path C):
   675	/// 1. Read existing `pinned_pubkeys.json`. Fail-closed if missing or
   676	///    unparseable.
   677	/// 2. Build `PinnedSystemPubkeys` from every manifest entry so all
   678	///    prior-epoch entries still verify.
   679	/// 3. Read existing `initial_q_state.json`. Fail-closed if missing.
   680	/// 4. Read every L4 entry from `refs/transitions/main`.
   681	/// 5. Replay via `replay_full_transition` — the canonical FC2 Boot
   682	///    replay primitive shared with `verify_chaintape`. Any replay
   683	///    failure is fail-closed (no partial admission per packet §5 Q1).
   684	/// 6. Generate a NEW keypair for a NEW epoch (`max_existing + 1`).
   685	///    Append the new entry to `pinned_pubkeys.json` on disk; old
   686	///    entries stay so prior commits still verify. Pin the new pubkey
   687	///    so new commits round-trip.
   688	fn bootstrap_resume_state(
   689	    runtime_repo_path: &Path,
   690	    cas_store: &CasStore,
   691	    git_writer: &Git2LedgerWriter,
   692	) -> Result<
   693	    (
   694	        Arc<Ed25519Keypair>,
   695	        SystemEpoch,
   696	        PinnedSystemPubkeys,
   697	        QState,
   698	        u64,
   699	    ),
   700	    BootstrapError,
   701	> {
   702	    // 1. Pinned pubkeys manifest — fail-closed if missing.
   703	    let manifest_path = runtime_repo_path.join(PINNED_PUBKEYS_FILENAME);
   704	    if !manifest_path.exists() {
   705	        return Err(BootstrapError::Keypair(format!(
   706	            "resume mode: pinned_pubkeys.json missing at {manifest_path:?}; \
   707	             cannot rebuild PinnedSystemPubkeys map for chain signature verification"
   708	        )));
   709	    }
   710	    let manifest_json = std::fs::read_to_string(&manifest_path)?;
   711	    let mut manifest: PinnedPubkeyManifest = serde_json::from_str(&manifest_json)
   712	        .map_err(|e| BootstrapError::Keypair(format!("pinned_pubkeys.json parse: {e}")))?;
   713	
   714	    // 2. Rehydrate PinnedSystemPubkeys from every manifest entry.
   715	    let mut pinned = PinnedSystemPubkeys::new();
   716	    let mut max_epoch: u64 = 0;
   717	    for entry in &manifest.pubkeys {
   718	        let bytes = decode_pubkey_hex_32(&entry.pubkey_hex)?;
   719	        pinned.insert(SystemEpoch::new(entry.epoch), SystemPublicKey::from_bytes(bytes));
   720	        if entry.epoch > max_epoch {
   721	            max_epoch = entry.epoch;
   722	        }
   723	    }
   724	
   725	    // 3. Initial QState — fail-closed if missing.
