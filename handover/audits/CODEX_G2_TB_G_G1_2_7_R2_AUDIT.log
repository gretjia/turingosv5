     1	//! TB-10 Atom 1 — Reusable preseed factory for chaintape genesis QState.
     2	//!
     3	//! Single source of truth for the initial `balances_t` map populated when a
     4	//! fresh chaintape is bootstrapped. Both the evaluator binary and the new
     5	//! `lean_market` user CLI call this factory so that whichever process
     6	//! bootstraps the chain first produces the SAME genesis QState — ensuring
     7	//! the user CLI and evaluator can both attach to the same on-disk chaintape
     8	//! and observe consistent balances.
     9	//!
    10	//! **Constitutional gate** (Art. III.4 / P3 kill #1 — "no post-init mint"):
    11	//! this factory is consumed ONLY at chaintape bootstrap (genesis QState
    12	//! construction via `runtime::adapter::genesis_with_balances`). It is NOT a
    13	//! runtime mint path. `assert_no_post_init_mint` continues to fire on every
    14	//! subsequent typed_tx and rejects any non-genesis mint attempt.
    15	//!
    16	//! **Replay determinism**: the function is pure (no env reads, no clock,
    17	//! no randomness). Two calls produce byte-identical Vec output. Past chains
    18	//! continue to replay from their on-disk genesis_report.json regardless of
    19	//! future edits to this factory; only fresh bootstraps consume the current
    20	//! version.
    21	//!
    22	//! Per `handover/audits/CHARTER_RATIFICATION_TB_10_2026-05-02.md` §1 Q2 +
    23	//! §2.4. Consolidates the inline literal previously at
    24	//! `experiments/minif2f_v4/src/bin/evaluator.rs:716-731`.
    25	
    26	use crate::economy::money::MicroCoin;
    27	use crate::state::q_state::AgentId;
    28	
    29	/// TRACE_MATRIX FC2 Boot: TB-10 Atom 1 — sponsor + user-sponsor + 10 solver agent budgets;
    30	/// **TB-N3 A0.5 (architect ruling 2026-05-11 amendment 6 + Q1+Q2 verdicts)**:
    31	/// + 1 MarketMakerBudget genesis preseed entry.
    32	///
    33	/// The 13 entries (in stable insertion order):
    34	///
    35	/// 1. `tb7-7-sponsor` (10_000_000 micro = 10 Coin) — TB-7.7 D3 self-funded
    36	///    sponsor used by evaluator's `--task-mode self|both` preseed branch
    37	///    (`evaluator.rs:864-922`). Preserved for back-compat with TB-7+
    38	///    smoke harness.
    39	/// 2. `Agent_user_0` (10_000_000 micro = 10 Coin) — **TB-10 Atom 1 net-new**;
    40	///    sponsor identity used by `lean_market post-task` subcommand.
    41	///    `Agent_user_` prefix is the audit_dashboard §11 filter convention
    42	///    (per ratification §2.3).
    43	/// 3-12. `Agent_0..9` (1_000_000 micro = 1 Coin each) — solver budgets;
    44	///    plenty for ~1000 WorkTx.stake at 1_000 each.
    45	/// 13. `MarketMakerBudget` (5_000_000 micro = 5 Coin) — **TB-N3 A0.5 net-new
    46	///     (2026-05-11; architect ruling Q2 + amendment 6)**: provider identity
    47	///     used by TB-N3 A3 `tb_n3_emit_node_market_after_work_accept` to seed
    48	///     `MarketSeedTx` + `CpmmPoolTx` against accepted WorkTx node markets.
    49	///     Sized at 10× safety margin over the architect's recommended Phase-2
    50	///     batch budget (architect Q1: DEFAULT_POOL_SEED = 100_000 microCoin
    51	///     × ~5 accepted WorkTx per 9-problem batch = 500_000 microCoin draw;
    52	///     5_000_000 micro budget = 10× headroom for stochastic batch growth).
    53	///     No special permission semantics: identity acts as ordinary preseed
    54	///     agent. Genesis insertion (NOT post-init mint) preserves
    55	///     `assert_no_post_init_mint`; A3 helper signs each
    56	///     TaskOpen/MarketSeed/CpmmPool tx via canonical agent paths.
    57	///
    58	/// Total preseed supply = 10_000_000 + 10_000_000 + 10 × 1_000_000 + 5_000_000
    59	/// = 35_000_000 micro = 35 Coin.
    60	///
    61	/// **Why not env-driven**: env-driven preseed would break replay determinism
    62	/// (genesis QState would depend on env at bootstrap time). The factory is
    63	/// the deterministic substrate; specific runs that need different starting
    64	/// balances should construct their own preseed Vec and call
    65	/// `genesis_with_balances` directly.
    66	pub fn default_pput_preseed_pairs() -> Vec<(AgentId, MicroCoin)> {
    67	    let mut pairs: Vec<(AgentId, MicroCoin)> = vec![
    68	        (
    69	            AgentId("tb7-7-sponsor".into()),
    70	            MicroCoin::from_micro_units(10_000_000),
    71	        ),
    72	        (
    73	            AgentId("Agent_user_0".into()),
    74	            MicroCoin::from_micro_units(10_000_000),
    75	        ),
    76	    ];
    77	    for i in 0..10 {
    78	        pairs.push((
    79	            AgentId(format!("Agent_{i}")),
    80	            MicroCoin::from_micro_units(1_000_000),
    81	        ));
    82	    }
    83	    // TB-N3 A0.5 (architect ruling 2026-05-11 amendment 6 + Q2): the
    84	    // MarketMakerBudget agent is the canonical provider for TB-N3 A3
    85	    // auto-emitted node-market seed/pool transactions. 5M micro = 10×
    86	    // headroom over Phase-2 expected draw at DEFAULT_POOL_SEED = 100k
    87	    // micro per pool (architect Q1).
    88	    pairs.push((
    89	        AgentId("MarketMakerBudget".into()),
    90	        MicroCoin::from_micro_units(5_000_000),
    91	    ));
    92	    pairs
    93	}
