{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "turingos.v5.agent_identity.v0.8",
  "title": "AgentIdentity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "actor_id",
    "declared_role",
    "role_assignment_source",
    "role_assignment_ref",
    "role_assignment_cid",
    "assigned_by_actor_id",
    "provider_label",
    "runtime_label",
    "capabilities",
    "started_at"
  ],
  "properties": {
    "actor_id": {
      "type": "string",
      "minLength": 1
    },
    "declared_role": {
      "type": "string",
      "enum": [
        "MetaAI",
        "WorkerAI",
        "AuditorAI",
        "VetoAI",
        "HumanArchitect",
        "Unassigned"
      ]
    },
    "role_assignment_source": {
      "type": "string",
      "enum": [
        "human_prompt",
        "task_packet",
        "review_packet",
        "meta_continuation",
        "accepted_dev_event",
        "explicit_role_entry"
      ]
    },
    "role_assignment_ref": {
      "type": "string",
      "minLength": 1
    },
    "role_assignment_cid": {
      "type": "string",
      "minLength": 1
    },
    "assigned_by_actor_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_label": {
      "type": "string",
      "description": "Provider label is provenance only and not authority for any role.",
      "minLength": 1
    },
    "runtime_label": {
      "type": "string",
      "description": "Runtime label records execution context and never grants role authority.",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
