{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turingos.local/schemas/worker_report.schema.json",
  "title": "WorkerReport",
  "type": "object",
  "required": ["schema_version", "atom_id", "task_revision", "worker_slot", "branch", "pr_url", "files_changed", "tests_run", "forbidden_files_touched", "class4_touched", "new_dependencies"],
  "properties": {
    "schema_version": { "const": "worker_report/v0.7" },
    "atom_id": { "type": "string" },
    "task_revision": { "type": "integer", "minimum": 1 },
    "worker_slot": { "type": "string" },
    "branch": { "type": "string" },
    "pr_url": { "type": "string" },
    "files_changed": { "type": "array", "items": { "type": "string" } },
    "tests_run": { "type": "array" },
    "forbidden_files_touched": { "type": "boolean" },
    "class4_touched": { "type": "boolean" },
    "new_dependencies": { "type": "boolean" }
  }
}
