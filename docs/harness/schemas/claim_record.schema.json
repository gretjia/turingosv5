{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turingos.local/schemas/claim_record.schema.json",
  "title": "ClaimRecord",
  "type": "object",
  "required": ["schema_version", "atom_id", "task_revision", "worker_slot", "branch", "claim_pr", "claimed_at"],
  "properties": {
    "schema_version": { "const": "claim_record/v0.7" },
    "atom_id": { "type": "string" },
    "task_revision": { "type": "integer" },
    "worker_slot": { "type": "string" },
    "branch": { "type": "string" },
    "claim_pr": { "type": "string" },
    "claimed_at": { "type": "string" }
  }
}
